{
  "id": "/",
  "name": "Cross Device Audio Editor",
  "short_name": "AudioPWA",
  "description": "Simple audio editor that works across devices.",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay","standalone","browser"],
  "orientation": "portrait",
  "lang": "en",
  "dir": "ltr",

  "theme_color": "#141414",
  "background_color": "#141414",

  "categories": ["music","utilities","productivity"],

  "icons": [
    {
      "src": "lib/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "lib/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "lib/icon-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "shortcuts": [
    {
      "name": "Add Audio",
      "short_name": "Add",
      "url": "/index.html?action=add",
      "icons": [{ "src": "lib/add.png", "sizes": "192x192" }]
    },
    {
      "name": "Open Editor",
      "short_name": "Edit",
      "url": "/index.html?action=edit",
      "icons": [{ "src": "lib/edit.png", "sizes": "192x192" }]
    }
  ],

  "screenshots": [
    {
      "src": "lib/screen1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide"
    },
    {
      "src": "lib/screen2.png",
      "sizes": "720x1280",
      "type": "image/png"
    }
  ]
}